{
  "name": "nokiao-copilot-chat",
  "version": "0.0.1",
  "description": "agui",
  "main": "index.ts",

  "scripts": {
    "build:js::dev": "webpack --mode development",
    "build:js": "webpack",
    "build:backends": "dash-generate-components ./src/ts/components nokiao_copilot_chat -p package-info.json  --ignore \\.test\\. && python scripts/postprocess_dash_init.py",
    "build": "npm run build:js && npm run build:backends",
    "watch": "npm run build:js::dev -- --watch",
    "dist": "python -m build --sdist --wheel --outdir dist/",
    "format":  "prettier --write src --ignore-path=.prettierignore"
  },
  "devDependencies": {
    "@copilotkit/react-core": "1.52.1",
    "@copilotkit/react-ui": "1.52.1",
    "@copilotkit/runtime": "1.52.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "css-loader": "^6.10.0",
    "npm-run-all": "^4.1.5",
    "react": "18.2.0",
    "react-docgen": "^5.4.3",
    "react-dom": "18.2.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.3.1",
    "typescript": "^5.6.3",
    "webpack": "^5.101.0",
    "webpack-cli": "^5.1.4",
    "prettier": "^3.2.4"
  },
  "peerDependencies": {
    "react": "16 - 19",
    "react-dom": "16- 19"
  },
  "author": "luoja <675925864@qq.com>",
  "license": "MIT"
}
